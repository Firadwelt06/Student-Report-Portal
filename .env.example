DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Use sqlite for first local run, or mysql for your production-like setup.
DATABASE_ENGINE=sqlite

# MySQL settings, used only when DATABASE_ENGINE=mysql.
MYSQL_DATABASE=student_result_portal
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
